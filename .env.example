# --- Storage ---------------------------------------------------------------
# Backend priority: Firebase Firestore > Postgres (Neon) > local ndjson file.
#
# RECOMMENDED (persistent on Netlify): Firebase Firestore. Create a Firebase
# project, enable Firestore, then Project settings -> Service accounts ->
# "Generate new private key". Copy these three values out of that JSON:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the PEM as a single line with literal \n between lines, wrapped in quotes:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=
# Optional: Firestore collection name (default "responses").
# FIREBASE_COLLECTION=responses

# Alternative store: Postgres connection string (Neon). Used only if the
# FIREBASE_* vars above are unset.
DATABASE_URL=

# If NONE of the above are set, responses go to ./.data/responses.ndjson
# (local dev only; Netlify/Vercel filesystems are read-only, so set Firebase
# before collecting real data).

# --- Security --------------------------------------------------------------
# Secret used to sign the per-round tokens that hide which solution is TRIZ.
# MUST be set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Token required to read /api/export and /api/stats (and the /results page).
EXPORT_TOKEN=change-me

# --- Game config (client-visible) ------------------------------------------
# Comparisons shown per session. There are 8 ELEC-042 pairs, so 8 shows each once.
NEXT_PUBLIC_SESSION_LENGTH=8
